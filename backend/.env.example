
# ================= Database =================
# PostgreSQL database name
POSTGRES_DB=
# PostgreSQL host (e.g., db or localhost)
POSTGRES_HOST=
# PostgreSQL port (default: 5432)
POSTGRES_PORT=

# ================= Vault =================
# Path to the CA certificate for Vault (optional, for self-signed certs)
VAULT_CACERT=
# Vault server address (e.g., https://vault:8200)
VAULT_ADDR=

# ================= JWT =================
# Access token expiration in milliseconds (e.g., 900000 for 15 minutes)
JWT_ACCESS_TOKEN_EXPIRATION_MS=
# Refresh token expiration in milliseconds (e.g., 604800000 for 7 days)
JWT_REFRESH_TOKEN_EXPIRATION_MS=

# ================= Node Environment =================
# Node environment (development, production, etc.)
NODE_ENV=

# ================= Google OAuth =================
# Google OAuth redirect URI (e.g., https://localhost/api/auth/google/callback)
GOOGLE_AUTH_REDIRECT_URI=

# ================= Auth UI =================
# URL to redirect to after authentication (e.g., https://localhost/)
AUTH_UI_REDIRECT=

# ================= Bcrypt =================
# Number of salt rounds for bcrypt password hashing (e.g., 10)
BCRYPT_SALT_ROUNDS=
