
# ================= Vault =================
# Path to the CA certificate for Vault inside the container (e.g., /path/to/ca.crt)
VAULT_CACERT=
# Vault server address (e.g., https://vault:8200)
VAULT_ADDR=

# ================= Database =================
# PostgreSQL database name
POSTGRES_DB=
# PostgreSQL host (e.g., db or localhost)
POSTGRES_HOST=
# PostgreSQL port (default: 5432)
POSTGRES_PORT=

# ================= App =================
# Port for the backend server to listen on (e.g., 3000)
PORT=

# ================= Cache =================
# Redis password (if set)
REDIS_PASSWORD=
# Redis connection URL (e.g., redis://:password@host:port/0)
REDIS_URL=

# ================= Google OAuth =================
# Google OAuth redirect URI (e.g., https://localhost/api/auth/google/callback)
GOOGLE_AUTH_REDIRECT_URI=

# ================= Auth UI =================
# URL to redirect to after authentication (e.g., https://localhost/dashboard)
AUTH_UI_REDIRECT=

# ================= Bcrypt =================
# Number of salt rounds for bcrypt password hashing (e.g., 10)
BCRYPT_SALT_ROUNDS=
